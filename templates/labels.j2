{% if cadvisor_container_labels_traefik_enabled %}
traefik.enable=true

{% if cadvisor_container_labels_traefik_docker_network %}
traefik.docker.network={{ cadvisor_container_labels_traefik_docker_network }}
{% endif %}

{% set middlewares = [] %}

{% if cadvisor_container_labels_traefik_middleware_basic_auth_enabled %}
{% set middlewares = middlewares + [cadvisor_identifier + '-basic-auth'] %}
traefik.http.middlewares.{{ cadvisor_identifier }}-basic-auth.basicauth.users={{ cadvisor_container_labels_traefik_middleware_basic_auth_users }}
{% endif %}

{% if cadvisor_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ cadvisor_identifier }}-slashless-redirect.redirectregex.regex=^({{ cadvisor_container_labels_traefik_path_prefix | quote }})$
traefik.http.middlewares.{{ cadvisor_identifier }}-slashless-redirect.redirectregex.replacement=${1}/
{% set middlewares = middlewares + [cadvisor_identifier + '-slashless-redirect'] %}
{% endif %}

{% if cadvisor_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ cadvisor_identifier }}-strip-prefix.stripprefix.prefixes={{ cadvisor_container_labels_traefik_path_prefix }}
{% set middlewares = middlewares + [cadvisor_identifier + '-strip-prefix'] %}
{% endif %}

{% if cadvisor_container_labels_traefik_additional_request_headers.keys() | length > 0 %}
{% for name, value in cadvisor_container_labels_traefik_additional_request_headers.items() %}
traefik.http.middlewares.{{ cadvisor_identifier }}-add-request-headers.headers.customrequestheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [cadvisor_identifier + '-add-request-headers'] %}
{% endif %}

{% if cadvisor_container_labels_traefik_additional_response_headers.keys() | length > 0 %}
{% for name, value in cadvisor_container_labels_traefik_additional_response_headers.items() %}
traefik.http.middlewares.{{ cadvisor_identifier }}-add-response-headers.headers.customresponseheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [cadvisor_identifier + '-add-response-headers'] %}
{% endif %}

traefik.http.routers.{{ cadvisor_identifier }}.rule={{ cadvisor_container_labels_traefik_rule }}
{% if cadvisor_container_labels_traefik_priority | int > 0 %}
traefik.http.routers.{{ cadvisor_identifier }}.priority={{ cadvisor_container_labels_traefik_priority }}
{% endif %}
traefik.http.routers.{{ cadvisor_identifier }}.service={{ cadvisor_identifier }}
{% if middlewares | length > 0 %}
traefik.http.routers.{{ cadvisor_identifier }}.middlewares={{ middlewares | join(',') }}
{% endif %}
traefik.http.routers.{{ cadvisor_identifier }}.entrypoints={{ cadvisor_container_labels_traefik_entrypoints }}
traefik.http.routers.{{ cadvisor_identifier }}.tls={{ cadvisor_container_labels_traefik_tls | to_json }}
{% if cadvisor_container_labels_traefik_tls %}
traefik.http.routers.{{ cadvisor_identifier }}.tls.certResolver={{ cadvisor_container_labels_traefik_tls_certResolver }}
{% endif %}

traefik.http.services.{{ cadvisor_identifier }}.loadbalancer.server.port={{ cadvisor_container_http_port }}
{% endif %}

{% for arg in cadvisor_container_labels_additional_labels %}
{{ arg }}
{% endfor %}
